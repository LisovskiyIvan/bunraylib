{
  "name": "@dayme/bunraylib",
  "version": "0.1.0",
  "description": "TypeScript FFI bindings for raylib — zero dependencies, powered by Bun",
  "keywords": ["raylib", "ffi", "bun", "gamedev", "graphics"],
  "license": "MIT",
  "type": "module",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "lint": "oxlint src/*",
    "fmt": "oxfmt src/*",
    "progress": "bun run scripts/progress.ts",
    "prepublishOnly": "bun run lint"
  },
  "dependencies": {
    "@types/bun": "^1.3.11",
    "oxlint-tsgolint": "^0.23.0"
  },
  "devDependencies": {
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.3"
  }
}
